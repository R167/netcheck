#!/usr/bin/env bash
# Launch Claude Code with netcheck as an MCP server for interactive network investigation.
# Usage: ./neti [claude-code args...]
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BINARY="${SCRIPT_DIR}/netcheck"
if [[ ! -x "$BINARY" ]]; then
  echo "netcheck binary not found. Building..." >&2
  (cd "$SCRIPT_DIR" && go build -o netcheck .) || { echo "Build failed" >&2; exit 1; }
fi
exec claude --mcp-server "netcheck:${BINARY} --mcp" --allowedTools "mcp__netcheck__*" -p "You are a network security investigator. Use the netcheck MCP tools to thoroughly assess this network. Start with discover_network to find the gateway, then run targeted checks based on what you find. Explain findings clearly and suggest remediations." "$@"
