#!/usr/bin/env bash
# Launch Claude Code with netcheck as an MCP server for interactive network investigation.
# Usage: ./neti [claude-code args...]
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec claude --mcp-server "netcheck:${SCRIPT_DIR}/netcheck --mcp" --allowedTools "mcp__netcheck__*" -p "You are a network security investigator. Use the netcheck MCP tools to thoroughly assess this network. Start with discover_network to find the gateway, then run targeted checks based on what you find. Explain findings clearly and suggest remediations." "$@"
